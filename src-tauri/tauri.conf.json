{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Froglips",
  "version": "0.11.0",
  "identifier": "com.joseph.froglips",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 800,
        "height": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 19, "y": 36 }
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* https://huggingface.co https://civitai.com ipc: http://ipc.localhost asset: http://asset.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost https://*.civitai.com https://civitai.com",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.local-llm-app/images/*.png",
          "$HOME/.local-llm-app/images/**/*.png"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Jeritano/FrogLips/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk0NzAxMDlDRTZGNjg3NTcKUldSWGgvYm1uQkJ3bEhVM3UxUUl5cnlobmdPMWxGY3dqY2ZqcDJFS2tDcVhIWHVvOWVjTEtlUGEK"
    }
  }
}
